NCBI_API_KEY=your_ncbi_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional run settings (used by scripts/run_weekly_digest.sh)
# DAYS=7
# MAX_RESULTS=200
# AUTO_PROCEED=1
# SEND_EMAIL=1
# EMAIL_PROVIDER=brevo
# EMAIL_TO=you@example.com
# EMAIL_SUBJECT_PREFIX=Weekly ID + General Medicine Digest

# Brevo email provider (if EMAIL_PROVIDER=brevo)
# BREVO_API_KEY=your_brevo_api_key_here
# BREVO_SENDER_EMAIL=verified-sender@example.com
# BREVO_SENDER_NAME=ID Digest Bot

# SMTP email provider (if EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your_password_or_app_password
# SMTP_FROM=you@example.com
